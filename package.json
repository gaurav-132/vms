{
    "name": "vms",
    "private": true,
    "version": "0.1.0",
    "packageManager": "npm@10.5.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,html,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,css,html,json,md}\""
    },
    "devDependencies": {
        "prettier": "^3.8.1",
        "turbo": "^2.0.0"
    }
}
